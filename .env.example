# Shopify app credentials (from dev.shopify.com → your app → Client credentials)
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SCOPES=read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_products,write_products,customer_read_metaobjects,unauthenticated_read_metaobjects

# The public URL of this app (Vercel deployment URL)
SHOPIFY_APP_URL=https://figur-delivery.vercel.app

# Session storage: Upstash Redis
# Create a free database at https://console.upstash.com/
# Or use Vercel KV (which is Upstash under the hood)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: if the store uses a custom domain
# SHOP_CUSTOM_DOMAIN=figur.ae
